# ════════════════════════════════════════════════════════
# Frontend Environment Variables
# Copy this file to .env.local for local development.
# Set these as environment variables in Vercel / your host for production.
# ════════════════════════════════════════════════════════

# ── API URL ──────────────────────────────────────────────
# Development (local backend):
#   VITE_API_URL=http://localhost:5000/api
#
# Production (Render backend):
#   VITE_API_URL=https://skay-website-1.onrender.com/api
#
# This value is read by src/api/api.ts to build every request URL.
# It is also used by vite.config.ts to set the dev-server proxy target.
VITE_API_URL=https://skay-website-1.onrender.com/api

# ── Supabase ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (publishable key — safe to expose) ────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ── Supabase Storage bucket ──────────────────────────────
VITE_SUPABASE_STORAGE_BUCKET=product-images
