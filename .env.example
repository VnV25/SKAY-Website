# Example environment variables for local development.
# Copy this file to `.env` and fill in real values where needed.

# Frontend (Vite) — safe to expose to the browser
VITE_API_URL=/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_SUPABASE_STORAGE_BUCKET=product-images

# Serverless API (Vercel) — server-side only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
FRONTEND_ORIGIN=http://localhost:5173

# NOTE: Never expose `SUPABASE_SERVICE_ROLE_KEY` to the frontend.
